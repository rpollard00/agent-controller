# Agent Controller — Environment Variables
# Copy this file to .env and fill in your actual values.
# The .env file is git-ignored; only this .env.example is committed.

# Required: Azure DevOps Personal Access Token (PAT)
#   - Scopes needed: Work items: Read & write
#   - Create at: https://dev.azure.com/YOUR_ORG/_usersSettings/tokens
#   - The app reads this via "ENV:AZURE_DEVOPS_PAT" in appsettings.example.json
AZURE_DEVOPS_PAT=your_personal_access_token_here
