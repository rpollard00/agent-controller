{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AgentController.Api.FeedbackPollingWorker": "Debug",
      "AgentController.Api.PollingWorker": "Debug",
      "AgentController.Infrastructure.AzureDevOpsBoardsClient": "Debug",
    "AgentController.Infrastructure.AzureDevOpsReposPrLabelSource": "Debug",
      "AgentController.Application.Commands.IngestRuntimeEventCommandHandler": "Debug",
      "AgentController.Application.Services.RunLifecycleService": "Debug",
      "AgentController.Infrastructure.PiMateriaRuntime": "Debug"
    }
  },
  "AllowedHosts": "*",
  "agentController": {
    "workerId": "live-ado-worker",
    "workerEnabled": true,
    "pollIntervalSeconds": 30,
    "maxConcurrentRuns": 3,
    "staleTimeoutSeconds": 1800,
    "runRoot": "~/.agent-work-controller/runs",
    "retainSuccessfulRuns": true,
    "retainFailedRuns": true
  },
  "persistence": {
    "provider": "Sqlite",
    "connectionString": "Data Source=~/.agent-work-controller/agent-controller.db"
  },
  "workSource": {
    "provider": "AzureDevOpsBoards",
    "organizationUrl": "https://dev.azure.com/rpollard0630",
    "project": "Projecto",
    "eligibleTags": [
      "agent-ready"
    ],
    "excludedTags": [
      "agent-active",
      "agent-failed",
      "agent-needs-human"
    ],
    "eligibleStates": [
      "New"
    ],
    "activeState": "Active",
    "completedState": "Resolved",
    "maxComments": 50
  },
  "azureDevOps": {
    "personalAccessToken": "ENV:AZURE_DEVOPS_PAT"
  },
  "sourceControl": {
    "provider": "LocalGit"
  },
  "environmentProvider": {
    "provider": "LocalWorkspace"
  },
  "runtime": {
    "provider": "PiMateria",
    "controllerBaseUrl": "http://localhost:5103",
    "piExecutablePath": "pi"
  },
  "repositories": {
    "test1": {
      "cloneUrl": "git@ssh.dev.azure.com:v3/rpollard0630/Projecto/test1",
      "transport": "ssh",
      "defaultBranch": "main",
      "environmentProfile": "local-default",
      "runtimeProfile": "pi-materia-default"
    }
  },
  "feedback": {
    "enabled": true,
    "provider": "AzureDevOpsRepos",
    "pollIntervalSeconds": 60,
    "maxConcurrentPolls": 2,
    "soakMinutes": 5,
    "reworkMarkerTag": "agent-rework-requested",
    "allowedReviewers": [
      "rpollard@gmail.com"
    ],
    "maxReviewThreadsPerBundle": 50
  }
}
