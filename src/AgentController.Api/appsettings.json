{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AgentController.Api.PollingWorker": "Debug",
      "AgentController.Infrastructure.AzureDevOpsBoardsClient": "Debug"
    }
  },
  "AllowedHosts": "*",
  "agentController": {
    "workerId": "live-ado-worker",
    "workerEnabled": true,
    "pollIntervalSeconds": 30,
    "maxConcurrentRuns": 3,
    "staleTimeoutSeconds": 1800,
    "runRoot": "~/.agent-work-controller/runs",
    "retainSuccessfulRuns": true,
    "retainFailedRuns": true
  },
  "persistence": {
    "provider": "Sqlite",
    "connectionString": "Data Source=~/.agent-work-controller/agent-controller.db"
  },
  "workSource": {
    "provider": "AzureDevOpsBoards",
    "organizationUrl": "https://dev.azure.com/rpollard0630",
    "project": "Projecto",
    "eligibleTags": [
      "agent-ready"
    ],
    "excludedTags": [
      "agent-active",
      "agent-failed",
      "agent-needs-human"
    ],
    "eligibleStates": [
      "New",
      "Approved"
    ],
    "activeState": "In Progress",
    "completedState": "Done",
    "maxComments": 50
  },
  "azureDevOps": {
    "personalAccessToken": "ENV:AZURE_DEVOPS_PAT"
  },
  "sourceControl": {
    "provider": "LocalGit"
  },
  "environmentProvider": {
    "provider": "LocalWorkspace"
  },
  "runtime": {
    "provider": "PiMateria",
    "controllerBaseUrl": "http://localhost:5103",
    "piExecutablePath": "pi",
    "defaultMateriaLoadout": "Elena"
  },
  "repositories": {
    "test1": {
      "cloneUrl": "https://dev.azure.com/rpollard0630/Projecto/_git/test1",
      "defaultBranch": "main",
      "environmentProfile": "local-default",
      "runtimeProfile": "pi-materia-default"
    }
  }
}
