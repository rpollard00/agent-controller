{
  "agentController": {
    "workerId": "example-worker",
    "pollIntervalSeconds": 30,
    "maxConcurrentRuns": 3,
    "staleTimeoutSeconds": 1800,
    "runRoot": "~/.agent-work-controller/runs",
    "retainSuccessfulRuns": true,
    "retainFailedRuns": true
  },
  "persistence": {
    "provider": "Sqlite",
    "connectionString": "Data Source=~/.agent-work-controller/agent-controller.db"
  },
  "workSource": {
    // Provider: "AzureDevOpsBoards" to poll an Azure DevOps board, or "LocalFake" for offline testing.
    "provider": "AzureDevOpsBoards",

    // Azure DevOps organization URL (replace YOUR_ORG with your org name).
    "organizationUrl": "https://dev.azure.com/YOUR_ORG",

    // Azure DevOps project name within the organization.
    "project": "YOUR_PROJECT",

    // Tags that mark a work item as eligible for agent pickup.
    "eligibleTags": [
      "agent-ready"
    ],

    // Tags that exclude a work item even if it matches other criteria.
    "excludedTags": [
      "agent-blocked"
    ],

    // Board states considered eligible for polling (must match your process template).
    "eligibleStates": [
      "New",
      "Approved"
    ],

    // State the poller transitions a work item to when an agent begins execution.
    "activeState": "Active",

    // State the poller transitions a work item to when execution completes successfully.
    "completedState": "Resolved"
  },
  "azureDevOps": {
    // Personal Access Token. Use "ENV:VARIABLE_NAME" prefix to load from environment.
    // The PAT needs "Work items: Read & write" scope at minimum.
    "personalAccessToken": "ENV:AZURE_DEVOPS_PAT"
  },
  "sourceControl": {
    "provider": "LocalGit"
  },
  "environmentProvider": {
    "provider": "LocalWorkspace"
  },
  "runtime": {
    // Use "MockPiMateria" for simulated local runs (no pi installation needed).
    // Use "PiMateria" to launch a real `pi` child process (RPC mode) that drives
    // a pi-materia cast; runtime events flow back over HTTP to the controller's
    // POST /runs/{runId}/events endpoint (see docs/arch.md §13b).
    //
    // PiMateria requires:
    //   - controllerBaseUrl: this controller's HTTP origin (e.g. http://localhost:5103)
    //     so pi-materia can POST runtime.* events back here.
    //   - piExecutablePath: path to `pi` (default "pi", resolved via PATH).
    //   - defaultMateriaLoadout: the pi-materia loadout to use for casts.
    //
    // Example PiMateria block:
    //   "provider": "PiMateria",
    //   "controllerBaseUrl": "http://localhost:5103",
    //   "piExecutablePath": "pi",
    //   "defaultMateriaLoadout": "Wedge",
    //   "heartbeatsynthIntervalSeconds": 30
    "provider": "MockPiMateria",
    "piExecutablePath": "pi",
    "defaultMateriaLoadout": "success-pr"
  },
  "repositories": {
    "example-service": {
      "cloneUrl": "https://dev.azure.com/YOUR_ORG/YOUR_PROJECT/_git/example-service",
      "defaultBranch": "main",
      "environmentProfile": "local-default",
      "runtimeProfile": "pi-materia-default",
      "allowedPaths": [
        "src/",
        "tests/"
      ]
    },
    "local-test-repo": {
      "cloneUrl": "~/projects/my-test-repo",
      "defaultBranch": "main",
      "environmentProfile": "local-default",
      "runtimeProfile": "pi-materia-default"
    }
  },
  "localWork": {
    "definitions": [
      {
        "externalId": "local-task-1",
        "repoKey": "example-service",
        "title": "Add retry handling for transient failures",
        "body": "The service should retry transient HTTP 5xx responses up to 3 times with exponential backoff.",
        "acceptanceCriteria": {
          "given": "A service call receives a 503 response",
          "when": "The retry middleware is configured",
          "then": "The call is retried up to 3 times with exponential backoff"
        },
        "priority": 1,
        "status": "New",
        "tags": [
          "agent-ready",
          "enhancement"
        ]
      },
      {
        "repoKey": "example-service",
        "title": "Add health check endpoint",
        "body": "Add a /health endpoint that returns 200 when the service is healthy.",
        "tags": [
          "agent-ready",
          "feature"
        ]
      }
    ]
  }
}
